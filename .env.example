# Supabase Postgres — copy to .env and fill in the real password.
# Project ref: ggpubtmydqiywxlfpckx (region eu-north-1).

# Pooled (transaction) connection — normal app queries.
DATABASE_URL="postgresql://postgres.ggpubtmydqiywxlfpckx:[YOUR-PASSWORD]@aws-1-eu-north-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Session connection — migrations and the LISTEN/NOTIFY realtime worker.
DIRECT_URL="postgresql://postgres.ggpubtmydqiywxlfpckx:[YOUR-PASSWORD]@aws-1-eu-north-1.pooler.supabase.com:5432/postgres"

# Auth.js (NextAuth v5) — signs the session JWT. Generate your own:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="[GENERATE-A-RANDOM-SECRET]"
