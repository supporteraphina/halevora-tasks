# Supabase Postgres — copy to .env and fill in the real password.
# Project ref: ggpubtmydqiywxlfpckx (region eu-north-1).

# Pooled (transaction) connection — normal app queries.
DATABASE_URL="postgresql://postgres.ggpubtmydqiywxlfpckx:[YOUR-PASSWORD]@aws-1-eu-north-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Session connection — migrations and the LISTEN/NOTIFY realtime worker.
DIRECT_URL="postgresql://postgres.ggpubtmydqiywxlfpckx:[YOUR-PASSWORD]@aws-1-eu-north-1.pooler.supabase.com:5432/postgres"

# Auth.js (NextAuth v5) — signs the session JWT. Generate your own:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="[GENERATE-A-RANDOM-SECRET]"

# Public URL of the deployment (PRODUCTION only). Auth.js builds login/callback URLs from
# this when the app sits behind a proxy/load balancer. Local dev can leave it unset.
#   e.g. AUTH_URL="https://tasks.yourdomain.com"
AUTH_URL=

# Shared secret that gates the scheduled-worker endpoints (/api/recurrence/run,
# /api/automation/run) so an external cron can trigger them. Generate a random value.
# If unset, only a logged-in CEO can trigger them (never open to the world).
CRON_SECRET=

# Anthropic API key — powers the task description "AI assist" button (Section 4).
# OPTIONAL: leave blank and AI assist degrades gracefully (the button is disabled and
# the action returns a "set ANTHROPIC_API_KEY to enable" message). Set it to enable drafting.
ANTHROPIC_API_KEY=

# Supabase Storage — powers task attachments (Section 5). Server-side only; NEVER expose
# the service-role key to the client. OPTIONAL: leave SUPABASE_SERVICE_ROLE_KEY blank and
# attachments degrade gracefully (the panel shows a disabled "needs key" state; custom
# fields, comments, and activity are unaffected). SUPABASE_URL defaults to the project ref
# below when unset. Find the service-role key in Supabase → Project Settings → API.
SUPABASE_URL="https://ggpubtmydqiywxlfpckx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=
